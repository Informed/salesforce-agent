# Second Slack app (dev / parallel with production)
#
# SF_* are for the harness / local scripts (same as .env.sample); Bolt does not
# read them for InvokeHarness.
#
# Socket Mode allows one active connection per Slack app. To run this checkout
# while another process uses the main app, create a separate Slack app (see
# manifest.dev.json), copy this file to .env.dev, and fill in tokens from that
# app. Use: npm run start:dev
#
# Keep production on .env + npm start. Do not reuse tokens across the two files.

# HARNESS_ARN — same sources as production .env.sample: deploy output, agentcore status, or Bedrock console.
HARNESS_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:harness/my-agent-abc1234567

# AWS credentials for the Slack app process (caller of InvokeHarness).
# AWS_REGION=us-west-2

# Slack tokens — from the *dev* Slack app only (api.slack.com/apps → that app):
#   SLACK_BOT_TOKEN → OAuth & Permissions → Bot User OAuth Token
#   SLACK_APP_TOKEN → Basic Information → App-Level Tokens → connections:write
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Salesforce (harness only; same as .env.sample if you share a harness)
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=
SF_PRIVATE_KEY=
