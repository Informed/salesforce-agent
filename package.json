{
  "name": "salesforce-agent",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --skipLibCheck --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "start": "node app.js",
    "start:dev": "cross-env DOTENV_CONFIG_PATH=.env.dev node app.js",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "test": "find tests -name '*.test.js' -print0 | xargs -0 node --test",
    "sync:agentcore-harness": "cp scripts/sf-query.js agentcore-harness/scripts/sf-query.js && npm install --prefix agentcore-harness",
    "merge-harness-env": "node scripts/merge-harness-salesforce-env.mjs",
    "push-harness-env": "node scripts/push-harness-env-to-aws.mjs",
    "debug-sf-query": "node scripts/debug-sf-query.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "^3.1041.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1043.0",
    "@aws-sdk/client-secrets-manager": "^3.1043.0",
    "@aws-sdk/client-ssm": "^3.1043.0",
    "@slack/bolt": "^4.7.0",
    "axios": "^1.9.0",
    "dotenv": "~17.4.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@slack/cli-hooks": "^1.3.2",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
