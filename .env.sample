# Bolt (this process) needs HARNESS_ARN + Slack tokens below.
#
# Where to get each value (see README.md → "Slack tokens and HARNESS_ARN"):
#   SLACK_BOT_TOKEN — https://api.slack.com/apps → your app → OAuth & Permissions → Bot User OAuth Token (xoxb-…)
#   SLACK_APP_TOKEN — same app → Basic Information → App-Level Tokens → generate with scope connections:write (xapp-…)
#   HARNESS_ARN     — after `agentcore deploy`: CLI output, `agentcore status`, or AWS Console → Amazon Bedrock → AgentCore / harness
#
# Salesforce for SOQL: not read from this file at invoke time. Use .env.harness + npm run merge-harness-env,
# agentcore deploy, then npm run push-harness-env (see README and docs/agentcore-harness.md).

# Amazon Bedrock AgentCore — managed harness ARN (Slack app invokes via AWS SDK).
HARNESS_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:harness/my-agent-abc1234567

# AWS credentials for the Slack app process (caller of InvokeHarness).
# Use AWS_PROFILE, ~/.aws/credentials, or the default credential chain (e.g. ECS task role).
# AWS_REGION=us-west-2

# Optional: bump after merge/deploy/push-harness-env so AgentCore starts a NEW runtime session
# for the same Slack thread (otherwise a hot session can keep empty SF_* until idle expiry).
# HARNESS_RUNTIME_SESSION_SALT=v2

# Optional: `SALESFORCE_AGENT_DEBUG=1` → stderr lines prefixed `[salesforce-agent]` in the
# same terminal as `npm start` (harness invoke metadata only; no Slack tokens).
# SALESFORCE_AGENT_DEBUG=1

# Required for Slack (Socket Mode).
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Optional: local-only runs of scripts/sf-query.js from your laptop. For the deployed harness,
# use .env.harness + merge-harness-env (same JWT values are fine).
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=
SF_PRIVATE_KEY=
