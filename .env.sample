# Bolt (this process) needs HARNESS_ARN + Slack tokens below. SF_* are for the harness
# (sf-query.js) and local scripts — configure SF_* on the deployed harness in AWS, not only here.

# Amazon Bedrock AgentCore — managed harness ARN (Slack app invokes via AWS SDK).
# Create and deploy: see README.md and docs/agentcore-harness.md
HARNESS_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:harness/my-agent-abc1234567

# AWS credentials for the Slack app process (caller of InvokeHarness).
# Use AWS_PROFILE, ~/.aws/credentials, or the default credential chain (e.g. ECS task role).
# AWS_REGION=us-west-2

# Required for Slack (Socket Mode).
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Salesforce OAuth 2.0 JWT Bearer Flow Configuration
# Configure the same variables on the harness execution role / harness environment
# (custom container or AgentCore secrets) so the agent can run scripts/sf-query.js.
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_USERNAME=
SF_PRIVATE_KEY=
